# Normalize line endings to LF in the repo, checkout as-is on all platforms
* text=auto eol=lf

# Explicitly mark binary files to prevent corruption
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.db binary
*.sqlite binary
*.zip binary
*.xlsx binary
*.docx binary
*.pptx binary

# Always LF for these text types regardless of platform
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.html text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.css text eol=lf
