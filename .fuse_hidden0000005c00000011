function toggleCard(id) {
  const body = document.getElementById('body-' + id);
  const icon = document.getElementById('icon-' + id);
  body.classList.toggle('open');
  icon.classList.toggle('open');
}

function switchTouch(id, touch) {
  for (let i = 1; i <= 3; i++) {
    const content = document.getElementById('touch-' + id + '-' + i);
    const tabs = content.parentElement.querySelectorAll('.touch-tab');
    if (i === touch) {
      content.classList.add('active');
      tabs[i-1].classList.add('active');
    } else {
      content.classList.remove('active');
      tabs[i-1].classList.remove('active');
    }
  }
}

function copyMsg(btn, id) {
  const el = document.getElementById(id);
  navigator.clipboard.writeText(el.textContent).then(() => {
    btn.textContent = 'Copied!';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copy Message'; btn.classList.remove('copied'); }, 2000);
  });
}

function copySubject(btn, id) {
  const el = document.getElementById(id);
  const text = el.textContent.replace('Subject: ', '');
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = 'Copied!';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copy Subject'; btn.classList.remove('copied'); }, 2000);
  });
}

function filterAll() {
  document.querySelectorAll('.prospect-card').forEach(c => c.style.display = '');
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  document.querySelector('.filter-btn').classList.add('active');
}

function filterPriority(p) {
  document.querySelectorAll('.prospect-card').forEach(c => {
    c.style.display = c.dataset.priority == p ? '' : 'none';
  });
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
}

function filterAB(g) {
  document.querySelectorAll('.prospect-card').forEach(c => {
    c.style.display = c.dataset.ab == g ? '' : 'none';
  });
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
}

function updateStatus(id, status) {
  const card = document.getElementById('card-' + id);
  card.dataset.status = status;
  updateStats();
}

function updateStats() {
  const cards = document.querySelectorAll('.prospect-card');
  let sent = 0, replied = 0;
  cards.forEach(c => {
    const s = c.dataset.status;
    if (s && s.includes('sent')) sent++;
    if (s === 'replied' || s === 'meeting_booked') replied++;
  });
  document.getElementById('stat-sent').textContent = sent;
  document.getElementById('stat-replied').textContent = replied;
}
</script>
